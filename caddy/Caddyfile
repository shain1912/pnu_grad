# pnu-grad — Caddy 리버스 프록시 설정
# Caddy가 80/443 인증서 발급(Let's Encrypt) + 종단, 내부 Express(3001)로 프록시
#
# 실행: 이 폴더에서 `caddy run`  (또는 루트의 start-caddy.bat)
# 인증서 자동 발급/갱신. 첫 실행 시 80 포트로 HTTP-01 challenge 수신해야 함.

pnug.kodekorea.kr {
	encode zstd gzip
	reverse_proxy localhost:3001 {
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote_host}
	}

	# 보안 헤더
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		# CSP는 시안의 인라인 스크립트/CDN(Pretendard, GoogleFonts)과 충돌 가능 — 우선 보류
	}

	# 로그 (선택). caddy 폴더 내 access.log에 기록.
	log {
		output file ./access.log {
			roll_size 10mb
			roll_keep 5
		}
		format json
	}
}

# 만약 http://pnug.kodekorea.kr 접속이 들어오면 Caddy가 자동으로 https로 301 redirect함 (기본 동작).
