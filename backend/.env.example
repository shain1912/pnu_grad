# =====================================================================
# pnu-grad backend .env 예시
# 실제 .env 는 .gitignore 처리됨 — 이 파일은 변수 목록 참고용
# =====================================================================

# Server
PORT=3001
NODE_ENV=development          # production 시 secure 쿠키 + dist 정적 서빙 활성
FRONTEND_URL=http://localhost:5173

# 추가 origin 화이트리스트 (쉼표 구분, 선택)
# FRONTEND_ORIGINS=https://staging.example.com,http://192.168.1.50:5173

# === 신청자 인증 (Google OAuth) ===
JWT_SECRET=change-me-to-48-random-bytes-please-now
JWT_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
ALLOWED_EMAIL_DOMAIN=pusan.ac.kr

# === 관리자 인증 (자체 ID/PW) ===
ADMIN_JWT_EXPIRES_IN=2h
# 초기 1명 부트스트랩 (init-db 시 시드, 시드 후 비우는 것 권장)
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-on-first-init

# === Google Sheets 미러 (선택) ===
# 비우면 미러 비활성. 채우면 응답 제출 시 자동 append.
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_SA_KEY_PATH=./credentials/sheets-sa.json
GOOGLE_SHEETS_TAB=Responses

# =====================================================================
# Production 셋업 예시 (도메인: pnug.kodekorea.kr)
# =====================================================================
# NODE_ENV=production
# FRONTEND_URL=https://pnug.kodekorea.kr
# GOOGLE_REDIRECT_URI=https://pnug.kodekorea.kr/auth/google/callback
# JWT_SECRET=<openssl rand -base64 48>
# ADMIN_BOOTSTRAP_*  ← 시드 후 .env에서 제거
